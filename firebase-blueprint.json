{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "Blog posts, notices, and news",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Post title" },
        "content": { "type": "string", "description": "Post content in markdown or HTML" },
        "category": { "type": "string", "enum": ["notice", "event", "guide", "news", "startup"], "description": "Post category" },
        "thumbnail": { "type": "string", "description": "Thumbnail image URL" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Post tags" },
        "status": { "type": "string", "enum": ["draft", "published", "scheduled"], "description": "Publish status" },
        "isPinned": { "type": "boolean", "description": "Whether the post is pinned to top" },
        "publishedAt": { "type": "string", "format": "date-time", "description": "Publication date" },
        "authorId": { "type": "string", "description": "UID of the author" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "status", "authorId"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Consultation and reservation inquiries",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Inquirer name" },
        "phone": { "type": "string", "description": "Contact number" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "type": { "type": "string", "enum": ["resident", "non-resident", "meeting-room", "tour", "other"], "description": "Inquiry type" },
        "message": { "type": "string", "description": "Detailed message" },
        "status": { "type": "string", "enum": ["new", "contacted", "completed", "cancelled"], "description": "Processing status" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "type", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of blog posts and notices"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of consultation inquiries"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions"
    }
  }
}
